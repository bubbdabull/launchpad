{
  "name": "creator-launchpad",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "npx tsx src/lib/protocol/validate-protocol.ts",
    "clean": "rm -rf .next",
    "build": "next build --webpack",
    "build:turbo": "next build --turbopack",
    "start": "next start",
    "lint": "eslint \"src/app/api/**/*.{ts,tsx}\" \"src/lib/architecture/**/*.ts\" \"src/lib/protocol/**/*.ts\" --max-warnings 0",
    "enforce:protocol": "npx tsx src/lib/protocol/validate-protocol.ts",
    "enforce:layers": "npx tsx src/lib/protocol/validate-protocol.ts",
    "generate:genesis": "npx tsx scripts/generate-genesis-collection.ts",
    "generate:genesis:demo": "npx tsx scripts/generate-genesis-collection.ts --config scripts/demo-trait-config.json --out ./generated --count 3 --launch-seed demo-v1"
  },
  "dependencies": {
