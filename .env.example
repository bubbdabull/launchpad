# =============================================================================
# Creator Launchpad — environment template (copy to .env.local; never commit secrets)
# =============================================================================

# --- Site URL (no trailing slash; must match Privy “Allowed origins”) ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional alternative to anon key (newer Supabase projects)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional bucket override for collection assets (default: collection-assets)
# NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=
SUPABASE_SERVICE_ROLE_KEY=

# --- Session auth -------------------------------------------------------------
AUTH_SECRET=

# --- Privy (https://dashboard.privy.io) --------------------------------------
NEXT_PUBLIC_PRIVY_ENABLED=true
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- Solana (browser + server) -----------------------------------------------
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
# Browser RPC: override URL, or set Helius key (see src/lib/solana/cluster-public.ts)
# NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_HELIUS_API_KEY=
# Server RPC (API routes, server actions): override or Helius server key
SOLANA_RPC_URL=
HELIUS_API_KEY=

# Treasury: client needs NEXT_PUBLIC_* for mint tx; create/publish also accepts NEXT_PUBLIC if PLATFORM_TREASURY unset
NEXT_PUBLIC_PLATFORM_TREASURY=
PLATFORM_TREASURY=

# Anchor launch-controller program id (must match deployed bytecode)
# NEXT_PUBLIC_LAUNCH_CONTROLLER_PROGRAM_ID=

# Optional Meteora / mint tuning (see src/lib/launch/*)
# NEXT_PUBLIC_POOL_ACTIVATION_SLOTS_AHEAD=
# NEXT_PUBLIC_SOLANA_MINT_ADDRESS_LOOKUP_TABLES=
# NEXT_PUBLIC_RELAX_GENESIS_MINT_LIFECYCLE=

# Optional: create-flow deploy fee display (lamports; default 0.2 SOL)
# NEXT_PUBLIC_PLATFORM_DEPLOY_FEE_LAMPORTS=200000000

# Reown (WalletConnect) Cloud project id — required for Phantom / external wallet on
# mobile browsers with Privy (SDK throws if unset and user picks wallet login).
# Create a free project at https://cloud.reown.com and add the id here.
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: create form default for Genesis Pass share of the *trading-tax creator leg* (0–100).
# On-chain tax is fixed in launch-controller: 3% of swap volume, 20% of that tax to platform, remainder = creator leg,
# then nft_holder_share_bps splits the creator leg (see `src/lib/launch/trading-tax-protocol.ts`).
# NEXT_PUBLIC_PLATFORM_TRADING_DEFAULT_HOLDER_REWARD_PCT=50

# --- Admin (comma-separated Solana addresses) ---------------------------------
PLATFORM_ADMIN_WALLETS=

# --- Helius webhooks ----------------------------------------------------------
HELIUS_WEBHOOK_AUTH=

# --- Optional metadata --------------------------------------------------------
# NEXT_PUBLIC_METADATA_CREATED_ON=

# --- Pinata (IPFS — genesis CLI & uploads; server-only JWT) -------------------
# PINATA_JWT=
# PINATA_GATEWAY_URL=
# Genesis CLI loads `.env` / `.env.local` from repo root for `npm run generate:genesis*`.

# --- Optional API rate limits (see src/app/api/** envPositiveInt names) -------
# RATE_LIMIT_SIWS_VERIFY_MAX=30
# RATE_LIMIT_SIWS_VERIFY_WINDOW_MS=900000
# RATE_LIMIT_SIWS_NONCE_MAX=120
# RATE_LIMIT_SIWS_NONCE_WINDOW_MS=900000
# RATE_LIMIT_COLLECTION_UPLOAD_MAX=24
# RATE_LIMIT_COLLECTION_UPLOAD_WINDOW_MS=900000
# RATE_LIMIT_AI_METADATA_ENRICH_MAX=6
# RATE_LIMIT_AI_METADATA_ENRICH_WINDOW_MS=900000
# RATE_LIMIT_AI_METADATA_FIELD_MAX=12
# RATE_LIMIT_AI_METADATA_FIELD_WINDOW_MS=900000
# RATE_LIMIT_AI_LAUNCH_IMAGE_MAX=8
# RATE_LIMIT_AI_LAUNCH_IMAGE_WINDOW_MS=900000
# RATE_LIMIT_AI_FULL_PROJECT_MAX=3
# RATE_LIMIT_AI_FULL_PROJECT_WINDOW_MS=3600000

# --- Dev-only (architecture tooling) ------------------------------------------
# LAYER_DEV_WARNINGS=1
# L2_FULL_ENFORCE_AT_RUNTIME=1
# L2_INVARIANT_SOFT=1
