# Supabase (Project Settings → API): URL + anon key (legacy) or publishable key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# https://cloud.walletconnect.com — add for full RainbowKit + mobile/QR (WalletConnect v2)
# If unset, the app still runs with browser wallets (injected + MetaMask) only.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional defaults for the burn → mint panel (0x-prefixed, 42 chars)
NEXT_PUBLIC_BURN_COLLECTION=
NEXT_PUBLIC_MINT_COLLECTION=
NEXT_PUBLIC_MINT_PRICE_WEI=
NEXT_PUBLIC_LAUNCHPAD_FACTORY_ADDRESS=
# Default EVM chain for explorer / OpenSea trade links (e.g. 11155111 Sepolia, 1 mainnet)
NEXT_PUBLIC_DEFAULT_EVM_CHAIN_ID=11155111

# Hardhat deploy (evm/ folder) — never commit real private keys
SEPOLIA_RPC_URL=
DEPLOYER_PRIVATE_KEY=
# Optional alias Hardhat also reads:
# PRIVATE_KEY=
MINT_PRICE_WEI=
# Platform fee is fixed in contract at 2.5% (250 bps)
CREATOR_REWARD_BPS=0
PLATFORM_TREASURY=
# Genesis mint builds in the browser — must expose the same treasury pubkey here (and on Netlify).
NEXT_PUBLIC_PLATFORM_TREASURY=
ATTESTOR_ADDRESS=
# Server-side signer for /api/attest/solana-burn (never expose client-side)
ATTESTOR_PRIVATE_KEY=
# Chain ID where BurnMintGateway is deployed — must match on-chain mint calls (e.g. 11155111 Sepolia)
ATTEST_CHAIN_ID=11155111
# Solana RPC for burn verification
SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/UxZhvdWcMr0o5Ag_kyeQ2
# Storefront platform fee in basis points (e.g. 250 = 2.5%)
PLATFORM_STORE_FEE_BPS=250
# Optional client display copy for storefront fee preview
NEXT_PUBLIC_PLATFORM_STORE_FEE_BPS=250

# Launch-controller (Anchor) program invoked by deploy step 3 / genesis mint. Must match
# `declare_id!` in anchor/programs/launch-controller and the bytecode at that address on your cluster.
# If logs show DeclaredProgramIdMismatch (4100), redeploy with `anchor upgrade` or set this to your deployed id.
# NEXT_PUBLIC_LAUNCH_CONTROLLER_PROGRAM_ID=

# Solana launchpad — optional Genesis mint gate (see src/lib/launch/genesis-mint-config.ts)
# unset = relaxed in `next dev`, strict in production | true = relaxed everywhere | false = strict everywhere
# NEXT_PUBLIC_RELAX_GENESIS_MINT_LIFECYCLE=
# Solana launchpad (create form — UI defaults for trading-fee copy only)
# NEXT_PUBLIC_PLATFORM_TRADING_PLATFORM_BPS=100
# NEXT_PUBLIC_PLATFORM_TRADING_DEFAULT_HOLDER_REWARD_PCT=50

# App auth
AUTH_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Privy (https://dashboard.privy.io) — wallet + email/social sign-in
# NEXT_PUBLIC_PRIVY_ENABLED=true
# NEXT_PUBLIC_PRIVY_APP_ID=
# PRIVY_APP_SECRET=
# In the Privy app: add this site’s exact origin under Allowed origins / allowed URLs
# (e.g. http://localhost:3000 and your production https://…). If it doesn’t match,
# wallet login often fails in the modal with a generic “try connecting again” message.

# Optional API rate limits (per client IP, in-memory per server instance)
# RATE_LIMIT_ATTEST_MAX=20
# RATE_LIMIT_ATTEST_WINDOW_MS=900000
# RATE_LIMIT_CHECKOUT_MAX=60
# RATE_LIMIT_CHECKOUT_WINDOW_MS=900000
# RATE_LIMIT_SIWE_VERIFY_MAX=30
# RATE_LIMIT_SIWE_VERIFY_WINDOW_MS=900000
# RATE_LIMIT_SIWE_NONCE_MAX=120
# RATE_LIMIT_SIWE_NONCE_WINDOW_MS=900000
